# Railway Environment Variables Template
# Copy these to your Railway backend service

# ============================================================================
# DATABASE (Auto-populated by Railway)
# ============================================================================
DATABASE_URL=${{Postgres.DATABASE_URL}}

# ============================================================================
# SECURITY (REQUIRED - Generate your own!)
# ============================================================================
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-32-CHARACTER-STRING

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
OFFLINE_MODE=false
PORT=8000
PYTHONUNBUFFERED=1

# ============================================================================
# OPTIONAL: AI Grading (if you want AI-powered essay grading)
# ============================================================================
# Get free API key from: https://huggingface.co/settings/tokens
# HUGGINGFACE_API_KEY=hf_your_token_here

# ============================================================================
# NOTES
# ============================================================================
# 1. DATABASE_URL: Automatically set by Railway when you add PostgreSQL
# 2. SECRET_KEY: MUST be changed! Generate a secure random string
# 3. OFFLINE_MODE: Set to 'false' for production (Railway deployment)
# 4. PORT: Railway automatically sets this, but 8000 is the default
# 5. PYTHONUNBUFFERED: Ensures logs appear in real-time

# ============================================================================
# HOW TO ADD THESE IN RAILWAY
# ============================================================================
# 1. Go to your Railway project
# 2. Click on your backend service
# 3. Go to "Variables" tab
# 4. Click "+ New Variable"
# 5. Add each variable name and value
# 6. Click "Add" for each one
# 7. Railway will automatically restart your service

# ============================================================================
# SECURITY CHECKLIST
# ============================================================================
# ✅ Changed SECRET_KEY from default
# ✅ DATABASE_URL is set to ${{Postgres.DATABASE_URL}}
# ✅ OFFLINE_MODE is set to 'false'
# ✅ No sensitive data in git repository
# ✅ All passwords are strong and unique

# ============================================================================
# VERIFICATION
# ============================================================================
# After adding variables, test your backend:
# curl https://your-backend-url.railway.app/health
#
# Should return:
# {"status":"healthy","service":"Morning Quiz API","version":"2.0-ANTI-CHEAT"}
